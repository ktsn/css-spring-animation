{
  "name": "@ktsn/spring",
  "version": "0.19.0",
  "description": "Spring animation library for Vue.js",
  "keywords": [
    "spring",
    "animation",
    "vue"
  ],
  "author": "Katashin",
  "license": "MIT",
  "homepage": "https://github.com/ktsn/spring",
  "repository": {
    "type": "git",
    "url": "https://github.com/ktsn/spring.git"
  },
  "type": "module",
  "files": [
    "dist",
    "types"
  ],
  "main": "./dist/ktsn-spring.umd.cjs",
  "module": "./dist/ktsn-spring.js",
  "types": "./types/vue/index.d.ts",
  "exports": {
    ".": {
      "types": "./types/vue/index.d.ts",
      "import": "./dist/ktsn-spring.js",
      "require": "./dist/ktsn-spring.umd.cjs"
    }
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build --config vite.lib.config.ts",
    "dts": "vue-tsc",
    "typecheck": "vitest --typecheck",
    "test": "vitest",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "demo": "vite build",
    "publish": "./scripts/publish.sh"
  },
  "peerDependencies": {
    "vue": "^3.0.0"
  },
  "devDependencies": {
    "@types/node": "25.6.0",
    "@vitejs/plugin-vue": "6.0.6",
    "conventional-changelog-cli": "5.0.0",
    "jsdom": "29.1.1",
    "prettier": "3.8.3",
    "typescript": "6.0.3",
    "vite": "8.0.10",
    "vitest": "4.1.5",
    "vue": "3.5.34",
    "vue-tsc": "3.2.8"
  },
  "packageManager": "pnpm@11.0.7+sha512.724a7b5d2319cdd7009d65e15a2c29aae9d3902b50585ca163d38a7737eb85bc4e72196879ff59768a71e81fe32aa71e8b70f088b2e24b9e4a2850d87e4607b5"
}
